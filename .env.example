# Copy to .env and fill in real values. .env is gitignored.

# --- football-data.org v4 API ---
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION=PL
FOOTBALL_DATA_SEASON=2024

# --- Snowflake destination (soccer recruitment) ---
# ACCOUNT format: <orgname>-<account_name>  (e.g. ABCDEF-XY12345). Find it in the Snowsight URL.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=SOCCER_RECRUITMENT
SNOWFLAKE_SCHEMA=RAW

# --- Firecrawl (web scraping) ---
FIRECRAWL_API_KEY=
